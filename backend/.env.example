# AWS S3 (Used when ENV_MODE=prod)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_STORAGE_BUCKET_NAME=
AWS_S3_REGION_NAME=us-east-1

# Paystack
PAYSTACK_SECRET_KEY=sk_test_your_key_here
