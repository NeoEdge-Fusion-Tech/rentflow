ENV_MODE=dev
FREE_TIER_MONTHLY_QUOTA=10

DB_NAME=postgres
DB_USERNAME=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432


RESEND_API_KEY=
